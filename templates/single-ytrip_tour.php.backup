<!-- ==================== INLINE STYLES (brand-aware, dark-mode ready) ==================== -->
<style>
/* ===== Single hero: full width + full viewport like homepage, under header ===== */
.ytrip-single-hero.ytrip-single-hero--fullwidth,
.ytrip-single-hero.ytrip-single-hero--width-full {
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    margin-top: 0;
    padding-top: 0;
    box-sizing: border-box;
}
.ytrip-single-hero.ytrip-single-hero--viewport {
    min-height: min(58vh, 480px);
    display: flex;
    align-items: center;
}

/* Hero slider: Swiper layout */
.ytrip-single-hero.ytrip-hero-slider {
    overflow: hidden;
}
.ytrip-single-hero.ytrip-hero-slider .ytrip-hero-bg.swiper-wrapper {
    position: absolute;
    inset: 0;
    display: flex;
    flex-wrap: nowrap;
}
.ytrip-single-hero.ytrip-hero-slider .swiper-slide.ytrip-hero-slide-bg {
    flex: 0 0 100%;
    width: 100%;
    min-width: 100%;
    height: 100%;
    position: relative;
}
.ytrip-single-hero.ytrip-hero-slider .ytrip-hero-slide-bg .ytrip-hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.ytrip-single-hero .ytrip-hero__overlay,
.ytrip-single-hero .ytrip-hero-overlay {
    pointer-events: none;
}
/* Single hero content: full width for grid (homepage uses max-width 900px) */
.ytrip-single-hero .ytrip-hero__content {
    max-width: none;
    width: 100%;
    text-align: left;
}
.ytrip-single-hero .swiper-pagination,
.ytrip-single-hero .swiper-button-next,
.ytrip-single-hero .swiper-button-prev {
    z-index: 2;
}

/* ===== Base: hero under header, not full viewport ===== */
.ytrip-single-hero {
    position: relative;
    min-height: min(58vh, 480px);
    display: flex;
    align-items: center;
    overflow: hidden;
}

.ytrip-hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
}

.ytrip-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.ytrip-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    /* Fallback gradient; actual color set inline from homepage overlay options */
    background: linear-gradient(135deg, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.6) 100%);
}

.ytrip-hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 80px 0;
    color: #fff;
}

.ytrip-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 24px);
    width: 100%;
    box-sizing: border-box;
}

.ytrip-hero-grid {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: clamp(32px, 4vw, 60px);
    align-items: start;
}

/* ===== Hero Info ===== */
.ytrip-breadcrumb {
    font-size: 14px;
    margin-bottom: 20px;
    opacity: 0.8;
}

.ytrip-breadcrumb a {
    color: #fff;
    text-decoration: none;
}

.ytrip-breadcrumb .separator {
    margin: 0 8px;
}

.ytrip-hero-categories {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
}

.ytrip-category-badge {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
}

.ytrip-hero-title {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 800;
    line-height: 1.2;
    margin: 0 0 24px;
}

.ytrip-hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 24px;
}

.ytrip-meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
}

.ytrip-hero-rating {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
}

.ytrip-stars {
    display: flex;
    gap: 2px;
    color: var(--ytrip-accent, #f59e0b);
}

.ytrip-rating-value {
    font-weight: 700;
    font-size: 18px;
}

.ytrip-rating-count {
    opacity: 0.8;
    font-size: 14px;
}

.ytrip-hero-excerpt {
    font-size: 18px;
    line-height: 1.6;
    opacity: 0.9;
    max-width: 600px;
}

/* ===== Booking Card ===== */
.ytrip-hero-booking {
    position: relative;
}

.ytrip-booking-card {
    background: color-mix(in srgb, var(--ytrip-surface, #fff) 95%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 16px;
    padding: 28px;
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.15);
    border: 1px solid var(--ytrip-border, rgba(0,0,0,0.06));
    position: sticky;
    top: 100px;
}

.ytrip-booking-card--sheet {
    position: static;
    box-shadow: none;
    padding: 0 0 24px;
}

.ytrip-dark-mode .ytrip-booking-card,
[data-theme="dark"] .ytrip-booking-card {
    background: color-mix(in srgb, var(--ytrip-surface) 95%, transparent);
    color: var(--ytrip-text);
}

.ytrip-booking-price {
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(0,0,0,0.1);
}

.ytrip-price-label {
    font-size: 12px;
    text-transform: uppercase;
    color: var(--ytrip-text-muted, #64748b);
}

.ytrip-price-original {
    font-size: 18px;
    text-decoration: line-through;
    color: var(--ytrip-text-light, #94a3b8);
    margin-left: 8px;
}

.ytrip-price-current {
    font-size: 36px;
    font-weight: 800;
    color: var(--ytrip-primary, #2563eb);
    display: block;
}

.ytrip-price-per {
    font-size: 14px;
    color: var(--ytrip-text-muted, #64748b);
}

.ytrip-dark-mode .ytrip-booking-price {
    border-color: rgba(255,255,255,0.1);
}

/* ===== Form ===== */
.ytrip-form-group {
    margin-bottom: 20px;
}

.ytrip-form-group label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 6px;
    color: var(--ytrip-text, #374151);
}

.ytrip-form-group input[type="date"],
.ytrip-form-group input[type="text"],
.ytrip-form-group input[type="email"],
.ytrip-form-group input[type="number"] {
    width: 100%;
    padding: 12px 16px;
    border: 2px solid var(--ytrip-border, #e5e7eb);
    border-radius: 8px;
    font-size: 16px;
    transition: all 0.2s;
}

.ytrip-form-group input:focus {
    outline: none;
    border-color: var(--ytrip-primary, #2563eb);
    box-shadow: 0 0 0 4px rgba(37,99,235,0.1);
}

.ytrip-number-input {
    display: flex;
    align-items: center;
    border: 2px solid var(--ytrip-border, #e5e7eb);
    border-radius: 8px;
    overflow: hidden;
}

.ytrip-number-input input {
    border: none;
    text-align: center;
    flex: 1;
    background: var(--ytrip-surface, #fff);
    color: var(--ytrip-text, #111);
}

.ytrip-number-btn {
    width: 44px;
    height: 44px;
    border: none;
    background: var(--ytrip-surface-alt, #f8fafc);
    font-size: 20px;
    cursor: pointer;
    transition: all 0.2s;
}

.ytrip-number-btn:hover {
    background: var(--ytrip-primary, #2563eb);
    color: #fff;
}

.ytrip-booking-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
    margin: 20px 0;
    border-top: 1px dashed var(--ytrip-border, #e5e7eb);
    border-bottom: 1px dashed var(--ytrip-border, #e5e7eb);
}

.ytrip-total-price {
    font-size: 24px;
    font-weight: 700;
    color: var(--ytrip-primary, #2563eb);
}

.ytrip-btn-book {
    width: 100%;
    padding: 16px;
    font-size: 16px;
    font-weight: 600;
    border: none;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--ytrip-primary, #2563eb), #7c3aed);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: all 0.3s;
}

.ytrip-btn-book:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(37,99,235,0.4);
}

.ytrip-booking-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 16px;
}

.ytrip-btn-outline {
    padding: 12px;
    background: transparent;
    border: 2px solid var(--ytrip-border, #e5e7eb);
    border-radius: 8px;
    color: var(--ytrip-text, #374151);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 14px;
    transition: all 0.2s;
}

.ytrip-btn-outline:hover {
    border-color: var(--ytrip-primary, #2563eb);
    color: var(--ytrip-primary, #2563eb);
}

.ytrip-booking-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid var(--ytrip-border, #e5e7eb);
}

.ytrip-trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--ytrip-text-muted, #64748b);
}

.ytrip-trust-item svg {
    color: var(--ytrip-success, #10b981);
}

/* ===== Gallery Strip ===== */
.ytrip-hero-gallery {
    position: relative;
    z-index: 2;
    margin-top: -40px;
    padding-bottom: 20px;
}

.ytrip-gallery-strip {
    display: flex;
    gap: 8px;
}

.ytrip-gallery-thumb {
    width: 60px;
    height: 60px;
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    border: 3px solid transparent;
    transition: all 0.2s;
}

.ytrip-gallery-thumb.active,
.ytrip-gallery-thumb:hover {
    border-color: var(--ytrip-primary, #2563eb);
    transform: scale(1.05);
}

.ytrip-gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.ytrip-gallery-more {
    width: 60px;
    height: 60px;
    border-radius: 8px;
    background: rgba(0,0,0,0.6);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    cursor: pointer;
}

/* ===== Main Content ===== */
.ytrip-single-main {
    padding: 60px 0 80px;
    background: var(--ytrip-bg, #fff);
    color: var(--ytrip-text, #1e293b);
}

.ytrip-content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 350px;
    gap: 50px;
}

.ytrip-section {
    margin-bottom: 50px;
}

.ytrip-section-title {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 24px;
    color: var(--ytrip-text, #1e293b);
}

.ytrip-section-title svg {
    color: var(--ytrip-primary, #2563eb);
}

.ytrip-section-content {
    font-size: 16px;
    line-height: 1.8;
}

.ytrip-section-content p {
    margin-bottom: 16px;
}

/* ===== Tour information (rich meta) ===== */
.ytrip-tour-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
    gap: 20px;
}

.ytrip-tour-info-item {
    margin: 0;
    padding: 18px 20px;
    background: var(--ytrip-surface-alt, #f8fafc);
    border: 1px solid var(--ytrip-border, #e5e7eb);
    border-radius: 12px;
    border-inline-start: 4px solid var(--ytrip-primary, #2563eb);
}

.ytrip-tour-info-label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ytrip-primary, #2563eb);
    margin: 0 0 8px 0;
}

.ytrip-tour-info-value {
    font-size: 15px;
    line-height: 1.6;
    color: var(--ytrip-text, #1e293b);
    margin: 0;
}

.ytrip-tour-info-value p:last-child {
    margin-bottom: 0;
}

/* ===== Highlights ===== */
.ytrip-highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(250px, 100%), 1fr));
    gap: 16px;
}

.ytrip-highlight-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    background: var(--ytrip-surface-alt, #f8fafc);
    border-radius: 10px;
}

.ytrip-highlight-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(16,185,129,0.1);
    color: var(--ytrip-success, #10b981);
    border-radius: 8px;
    flex-shrink: 0;
}

/* ===== Itinerary ===== */
.ytrip-itinerary-timeline {
    position: relative;
}

.ytrip-itinerary-day {
    display: flex;
    gap: 24px;
    padding-bottom: 32px;
    position: relative;
}

.ytrip-itinerary-day::before {
    content: '';
    position: absolute;
    left: 20px;
    top: 44px;
    bottom: 0;
    width: 2px;
    background: var(--ytrip-border, #e5e7eb);
}

.ytrip-itinerary-day:last-child::before {
    display: none;
}

.ytrip-day-marker {
    position: relative;
    z-index: 1;
}

.ytrip-day-number {
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ytrip-primary, #2563eb);
    color: #fff;
    border-radius: 50%;
    font-weight: 700;
}

.ytrip-day-content {
    flex: 1;
    background: var(--ytrip-surface, #fff);
    border: 1px solid var(--ytrip-border, #e5e7eb);
    border-radius: 12px;
    padding: 20px;
}

.ytrip-day-title {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 12px;
}

.ytrip-day-description {
    font-size: 15px;
    line-height: 1.7;
    color: var(--ytrip-text-muted, #64748b);
}

.ytrip-day-meals {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
}

.ytrip-meals-label {
    font-size: 13px;
    color: var(--ytrip-text-muted, #64748b);
}

.ytrip-meal-badge {
    padding: 4px 10px;
    background: color-mix(in srgb, var(--ytrip-warning, #f59e0b) 15%, transparent);
    color: var(--ytrip-warning, #f59e0b);
    font-size: 12px;
    font-weight: 500;
    border-radius: 4px;
}

/* ===== Included/Excluded ===== */
.ytrip-included-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
}

.ytrip-included-list,
.ytrip-excluded-list {
    list-style: none;
    padding: 0;
    margin: 0;
}

.ytrip-included-list li,
.ytrip-excluded-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--ytrip-border, #e5e7eb);
}

.ytrip-included-list li:last-child,
.ytrip-excluded-list li:last-child {
    border-bottom: none;
}

/* ===== FAQ ===== */
.ytrip-faq-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.ytrip-faq-item {
    border: 1px solid var(--ytrip-border, #e5e7eb);
    border-radius: 10px;
    overflow: hidden;
}

.ytrip-faq-question {
    width: 100%;
    padding: 18px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 16px;
    font-weight: 600;
    text-align: left;
    color: var(--ytrip-text, #1e293b);
}

.ytrip-faq-question:hover {
    background: var(--ytrip-surface-alt, #f8fafc);
}

.ytrip-faq-question svg {
    transition: transform 0.3s;
}

.ytrip-faq-item.active .ytrip-faq-question svg {
    transform: rotate(180deg);
}

.ytrip-faq-answer {
    padding: 0 20px;
    max-height: 0;
    overflow: hidden;
    transition: all 0.3s;
}

.ytrip-faq-item.active .ytrip-faq-answer {
    padding: 20px;
    max-height: 5000px;
}

/* ===== Sidebar ===== */
.ytrip-content-sidebar {
    position: sticky;
    top: 100px;
    height: fit-content;
}

.ytrip-sidebar-card {
    background: var(--ytrip-surface, #fff);
    border: 1px solid var(--ytrip-border, #e5e7eb);
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 24px;
}

.ytrip-single-tour-widget-area {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--ytrip-border, #e5e7eb);
}

.ytrip-single-tour-widget-area .ytrip-widget-area__widget {
    margin-bottom: 24px;
}

.ytrip-single-tour-widget-area .ytrip-widget-area__widget:last-child {
    margin-bottom: 0;
}

.ytrip-sidebar-title {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--ytrip-border, #e5e7eb);
}

.ytrip-info-list {
    margin: 0;
}

.ytrip-info-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid var(--ytrip-border, #e5e7eb);
}

.ytrip-info-item:last-child {
    border-bottom: none;
}

.ytrip-info-item dt {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--ytrip-text-muted, #64748b);
}

.ytrip-info-item dt svg {
    width: 16px;
    height: 16px;
}

.ytrip-info-item dd {
    font-size: 14px;
    font-weight: 500;
}

.ytrip-info-item dd a {
    color: var(--ytrip-primary, #2563eb);
    text-decoration: none;
}

.ytrip-difficulty-badge {
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 12px;
    text-transform: uppercase;
}

.difficulty-easy { background: var(--ytrip-success); color: #fff; }
.difficulty-moderate { background: var(--ytrip-warning); color: #fff; }
.difficulty-challenging { background: var(--ytrip-accent); color: #fff; }
.difficulty-extreme { background: var(--ytrip-error); color: #fff; }
.ytrip-dark-mode .difficulty-easy,
[data-theme="dark"] .difficulty-easy { background: #166534; color: #bbf7d0; }
.ytrip-dark-mode .difficulty-moderate,
[data-theme="dark"] .difficulty-moderate { background: #a16207; color: #fef08a; }
.ytrip-dark-mode .difficulty-challenging,
[data-theme="dark"] .difficulty-challenging { background: #c2410c; color: #ffedd5; }
.ytrip-dark-mode .difficulty-extreme,
[data-theme="dark"] .difficulty-extreme { background: #b91c1c; color: #fecaca; }

/* ===== Gallery Preview ===== */
.ytrip-gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
}

.ytrip-gallery-link {
    display: block;
    border-radius: 8px;
    overflow: hidden;
}

.ytrip-gallery-link img {
    width: 100%;
    height: 80px;
    object-fit: cover;
    transition: transform 0.3s;
}

.ytrip-gallery-link:hover img {
    transform: scale(1.1);
}

/* ===== FAB + Bottom Sheet (mobile only: no overlap, open/collapse) ===== */
.ytrip-booking-fab {
    display: none;
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 999;
    padding: 12px 16px;
    padding-bottom: max(12px, env(safe-area-inset-bottom));
    background: linear-gradient(to top, rgba(255,255,255,0.98) 70%, transparent);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    pointer-events: none;
}

.ytrip-booking-fab__btn {
    pointer-events: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
    min-height: 56px;
    padding: 14px 24px;
    border: none;
    border-radius: 28px;
    background: linear-gradient(135deg, var(--ytrip-primary, #2563eb), #7c3aed);
    color: #fff;
    font-size: 17px;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 8px 32px rgba(37,99,235,0.35);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    -webkit-tap-highlight-color: transparent;
}

.ytrip-booking-fab__btn:active {
    transform: scale(0.98);
}

.ytrip-booking-fab__price {
    font-size: 1.1em;
}

.ytrip-booking-fab__label {
    letter-spacing: 0.02em;
}

.ytrip-booking-fab__chevron {
    transition: transform 0.3s ease;
}

.ytrip-booking-sheet {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    pointer-events: none;
    visibility: hidden;
}

.ytrip-booking-sheet.is-open {
    pointer-events: auto;
    visibility: visible;
}

.ytrip-booking-sheet__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.4);
    opacity: 0;
    transition: opacity 0.3s ease;
}

.ytrip-booking-sheet.is-open .ytrip-booking-sheet__backdrop {
    opacity: 1;
}

.ytrip-booking-sheet__panel {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    max-height: 92vh;
    background: var(--ytrip-surface, #fff);
    border-radius: 20px 20px 0 0;
    box-shadow: 0 -8px 40px rgba(0,0,0,0.15);
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
    display: flex;
    flex-direction: column;
    padding-bottom: env(safe-area-inset-bottom);
}

.ytrip-booking-sheet.is-open .ytrip-booking-sheet__panel {
    transform: translateY(0);
}

.ytrip-booking-sheet__handle {
    width: 40px;
    height: 4px;
    background: var(--ytrip-border, #e5e7eb);
    border-radius: 2px;
    margin: 12px auto 8px;
    flex-shrink: 0;
}

.ytrip-booking-sheet__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 20px 16px;
    flex-shrink: 0;
}

.ytrip-booking-sheet__title {
    font-size: 20px;
    font-weight: 700;
    margin: 0;
    color: var(--ytrip-text, #1e293b);
}

.ytrip-booking-sheet__close {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: var(--ytrip-surface-alt, #f8fafc);
    border-radius: 12px;
    color: var(--ytrip-text-muted, #64748b);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    -webkit-tap-highlight-color: transparent;
}

.ytrip-booking-sheet__close:hover,
.ytrip-booking-sheet__close:focus-visible {
    background: var(--ytrip-border, #e5e7eb);
    color: var(--ytrip-text, #1e293b);
}

.ytrip-booking-sheet__body {
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
    padding: 0 20px 24px;
    overscroll-behavior: contain;
}

/* ===== Responsive: single column below 1024px ===== */
@media (max-width: 1023px) {
    .ytrip-hero-grid {
        grid-template-columns: 1fr;
    }

    .ytrip-hero-booking {
        display: none !important;
    }

    .ytrip-content-grid {
        grid-template-columns: 1fr;
        gap: 40px;
    }

    .ytrip-content-sidebar {
        position: static;
    }

    .ytrip-included-grid {
        grid-template-columns: 1fr;
    }

    .ytrip-tour-info-grid {
        grid-template-columns: 1fr;
    }
}

/* ===== Mobile only: FAB and bottom sheet (hidden on desktop/tablet) ===== */
@media (max-width: 767px) {
    .ytrip-booking-fab {
        display: block;
    }

    .ytrip-booking-sheet {
        display: block;
    }
}

@media (max-width: 767px) {
    .ytrip-single-hero {
        min-height: min(50vh, 420px);
    }

    .ytrip-hero-content {
        padding: clamp(32px, 8vw, 48px) 0 clamp(40px, 10vw, 56px);
    }

    .ytrip-hero-title {
        font-size: clamp(24px, 6vw, 32px);
    }

    .ytrip-hero-meta {
        flex-direction: column;
        gap: 12px;
    }

    .ytrip-hero-meta .ytrip-meta-item {
        font-size: 14px;
    }

    .ytrip-hero-excerpt {
        font-size: 16px;
    }

    .ytrip-hero-gallery {
        margin-top: -24px;
        padding-bottom: 16px;
    }

    .ytrip-gallery-strip {
        gap: 6px;
    }

    .ytrip-gallery-thumb,
    .ytrip-gallery-more {
        width: 48px;
        height: 48px;
    }

    .ytrip-single-main {
        padding: clamp(32px, 6vw, 48px) 0 max(80px, env(safe-area-inset-bottom) + 80px);
    }

    .ytrip-content-grid {
        gap: 32px;
    }

    .ytrip-section {
        margin-bottom: 36px;
    }

    .ytrip-section-title {
        font-size: clamp(18px, 4.5vw, 22px);
        margin-bottom: 20px;
    }

    .ytrip-highlights-grid {
        grid-template-columns: 1fr;
    }

    .ytrip-itinerary-day {
        flex-direction: column;
        gap: 16px;
        padding-bottom: 24px;
    }

    .ytrip-itinerary-day::before {
        display: none;
    }

    .ytrip-day-content {
        padding: 16px;
    }

    .ytrip-included-grid {
        gap: 24px;
    }

    .ytrip-sidebar-card {
        padding: 20px;
    }

    .ytrip-gallery-grid {
        grid-template-columns: repeat(3, 1fr);
        gap: 6px;
    }

    .ytrip-gallery-link img {
        height: 72px;
    }

    #ytrip-tour-map {
        height: 280px !important;
        min-height: 200px;
    }
}

@media (max-width: 479px) {
    .ytrip-container {
        padding-left: 16px;
        padding-right: 16px;
    }

    .ytrip-hero-title {
        font-size: 22px;
    }

    .ytrip-breadcrumb {
        font-size: 13px;
    }

    .ytrip-category-badge {
        padding: 4px 10px;
        font-size: 11px;
    }

    .ytrip-booking-sheet__panel {
        max-height: 85vh;
    }

    .ytrip-booking-sheet__body {
        padding-left: 16px;
        padding-right: 16px;
    }

    .ytrip-booking-actions {
        grid-template-columns: 1fr;
    }

    .ytrip-booking-trust {
        flex-direction: column;
    }

    .ytrip-tour-info-item {
        padding: 14px 16px;
    }

    .ytrip-section-content {
        font-size: 15px;
    }
}

@media (min-width: 1024px) {
    .ytrip-booking-fab,
    .ytrip-booking-sheet {
        display: none !important;
    }
}

@media (min-width: 1280px) {
    .ytrip-container {
        padding-left: 24px;
        padding-right: 24px;
    }

    .ytrip-content-grid {
        grid-template-columns: 1fr 380px;
        gap: 56px;
    }
}

@media (min-width: 1536px) {
    .ytrip-container {
        max-width: 1400px;
    }
}

@media (prefers-reduced-motion: reduce) {
    .ytrip-booking-sheet__panel,
    .ytrip-booking-sheet__backdrop,
    .ytrip-booking-fab__btn {
        transition-duration: 0.1ms;
    }
}

/* ===== Dark mode: single tour content uses semantic variables ===== */
.ytrip-dark-mode .ytrip-single .ytrip-content-main,
[data-theme="dark"] .ytrip-single .ytrip-content-main {
    background: var(--ytrip-bg);
    color: var(--ytrip-text);
}
.ytrip-dark-mode .ytrip-single .ytrip-section-title,
[data-theme="dark"] .ytrip-single .ytrip-section-title {
    color: var(--ytrip-text);
}
.ytrip-dark-mode .ytrip-single .ytrip-meta-block,
[data-theme="dark"] .ytrip-single .ytrip-meta-block {
    background: var(--ytrip-surface-alt);
    border-color: var(--ytrip-border);
    color: var(--ytrip-text);
}
</style>

<!-- ==================== INLINE SCRIPTS ==================== -->
<script>
(function() {
    'use strict';

    // Number Input Controls (hero + sheet forms)
    document.querySelectorAll('.ytrip-number-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var target = this.dataset.target;
            var input = document.getElementById(target);
            if (!input) return;
            var isPlus = this.classList.contains('plus');
            var min = parseInt(this.dataset.min || 0, 10);
            var max = parseInt(this.dataset.max || 100, 10);
            var current = parseInt(input.value, 10) || 0;

            if (isPlus) {
                input.value = Math.min(current + 1, max);
            } else {
                input.value = Math.max(current - 1, min);
            }

            input.dispatchEvent(new Event('change'));
        });
    });

    // Mobile booking sheet: open / close
    var fab = document.getElementById('ytrip-booking-fab');
    var fabBtn = document.getElementById('ytrip-booking-fab-btn');
    var sheet = document.getElementById('ytrip-booking-sheet');
    var sheetBackdrop = document.getElementById('ytrip-booking-sheet-backdrop');
    var sheetClose = document.getElementById('ytrip-booking-sheet-close');

    function openSheet() {
        if (!sheet) return;
        sheet.classList.add('is-open');
        sheet.setAttribute('aria-hidden', 'false');
        if (fab) fab.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = 'hidden';
        document.documentElement.style.overflow = 'hidden';
        sheetClose && sheetClose.focus();
    }

    function closeSheet() {
        if (!sheet) return;
        sheet.classList.remove('is-open');
        sheet.setAttribute('aria-hidden', 'true');
        if (fab) fab.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = '';
        document.documentElement.style.overflow = '';
        fabBtn && fabBtn.focus();
    }

    if (fabBtn) {
        fabBtn.addEventListener('click', function() {
            openSheet();
        });
    }

    if (sheetClose) {
        sheetClose.addEventListener('click', closeSheet);
    }

    if (sheetBackdrop) {
        sheetBackdrop.addEventListener('click', closeSheet);
    }

    sheet && sheet.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && sheet.classList.contains('is-open')) {
            closeSheet();
        }
    });

    // FAQ Accordion (expand/collapse answers)
    function initFaqAccordion() {
    document.querySelectorAll('.ytrip-faq-question').forEach(function(btn) {
            if (btn.dataset.ytripFaqBound) return;
            btn.dataset.ytripFaqBound = '1';
            btn.setAttribute('aria-expanded', 'false');
        btn.addEventListener('click', function() {
            var item = this.closest('.ytrip-faq-item');
                if (!item) return;
            var isOpen = item.classList.contains('active');

            document.querySelectorAll('.ytrip-faq-item').forEach(function(i) {
                i.classList.remove('active');
                    var q = i.querySelector('.ytrip-faq-question');
                    if (q) q.setAttribute('aria-expanded', 'false');
            });

            if (!isOpen) {
                item.classList.add('active');
                    btn.setAttribute('aria-expanded', 'true');
                }
            });
        });
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initFaqAccordion);
    } else {
        initFaqAccordion();
    }

    // Gallery lightbox is handled in single-tour.js (same-page, no external resources).

    // Dark Mode Toggle Check
    var savedTheme = localStorage.getItem('ytrip_theme');
    if (savedTheme === 'dark') {
        document.documentElement.classList.add('ytrip-dark-mode');
        document.documentElement.setAttribute('data-theme', 'dark');
    }

    window.ytripToggleDarkMode = function() {
        var isDark = document.documentElement.classList.contains('ytrip-dark-mode');
        if (isDark) {
            document.documentElement.classList.remove('ytrip-dark-mode');
            document.documentElement.setAttribute('data-theme', 'light');
            localStorage.setItem('ytrip_theme', 'light');
        } else {
            document.documentElement.classList.add('ytrip-dark-mode');
            document.documentElement.setAttribute('data-theme', 'dark');
            localStorage.setItem('ytrip_theme', 'dark');
        }
    };

})();
</script>

