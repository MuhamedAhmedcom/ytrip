<?php
/**
 * YTrip Single Tour Template
 * 
 * Professional ultra-modern UI/UX design
 * - Hero section with featured image + booking form
 * - Full tour details with beautiful layout
 * - All meta keys displayed elegantly
 *
 * @package YTrip
 * @since 2.1.1
 */

if (!defined('ABSPATH')) {
    exit;
}

// Get tour data
$tour_id = get_the_ID();
$meta = get_post_meta($tour_id, 'ytrip_tour_details', true);
$meta = is_array($meta) ? $meta : [];

// Normalize meta keys (support both Codestar tour-details and class-admin-config field names)
$duration_src = $meta['duration'] ?? $meta['tour_duration'] ?? [];
$meta['duration'] = is_array($duration_src) ? $duration_src : [];
if (empty($meta['what_to_bring']) && !empty($meta['things_to_bring'])) {
    $meta['what_to_bring'] = $meta['things_to_bring'];
}
if (empty($meta['know_before']) && !empty($meta['know_before_you_go'])) {
    $meta['know_before'] = $meta['know_before_you_go'];
}
$map_loc = $meta['map_location'] ?? [];
if (is_array($map_loc)) {
    $lat = $map_loc['lat'] ?? $map_loc['latitude'] ?? null;
    $lng = $map_loc['lng'] ?? $map_loc['longitude'] ?? null;
    if (empty($meta['map_lat']) && $lat !== null && $lat !== '') {
        $meta['map_lat'] = $lat;
    }
    if (empty($meta['map_lng']) && $lng !== null && $lng !== '') {
        $meta['map_lng'] = $lng;
    }
    if (!empty($map_loc['zoom']) && empty($meta['map_zoom'])) {
        $meta['map_zoom'] = $map_loc['zoom'];
    }
}

// Get terms
$settings = get_option('ytrip_settings', []);
$dest_slug = $settings['slug_destination'] ?? 'ytrip_destination';
$cat_slug = $settings['slug_category'] ?? 'ytrip_category';

$destinations = get_the_terms($tour_id, $dest_slug);
$categories = get_the_terms($tour_id, $cat_slug);

// Get price data (WooCommerce or tour meta - works with/without WC)
$product_id = get_post_meta($tour_id, '_ytrip_wc_product_id', true);
$product = $product_id && function_exists('wc_get_product') ? wc_get_product($product_id) : null;
$tour_price_html = '';
if (!$product) {
    $raw = get_post_meta($tour_id, '_ytrip_price', true);
    if ($raw !== '' && is_numeric($raw)) {
        $currency = (function_exists('YTrip_Helper') && method_exists('YTrip_Helper', 'get_currency_symbol')) ? YTrip_Helper::get_currency_symbol() : '';
        $tour_price_html = $currency . number_format_i18n((float) $raw, 2);
    }
}

// Gallery: support gallery, tour_gallery (array or comma-separated string). Merge featured image so hero can be slider when featured + gallery.
$raw_gallery = $meta['tour_gallery'] ?? $meta['gallery'] ?? [];
if (is_array($raw_gallery)) {
    $gallery_ids = array_filter(array_map('intval', $raw_gallery));
} else {
    $gallery_ids = array_filter(array_map('intval', explode(',', (string) $raw_gallery)));
}
$featured_img_id = has_post_thumbnail($tour_id) ? get_post_thumbnail_id($tour_id) : 0;
if (empty($gallery_ids) && $featured_img_id) {
    $gallery_ids = [ $featured_img_id ];
} elseif ($featured_img_id && ! in_array($featured_img_id, $gallery_ids, true)) {
    array_unshift($gallery_ids, $featured_img_id);
    $gallery_ids = array_values($gallery_ids);
}

// Single page hero: one control = single_image | slider | carousel (backward compat: single_hero_type + gallery_display_mode)
$hero_mode = isset( $meta['hero_gallery_mode'] ) ? sanitize_key( $meta['hero_gallery_mode'] ) : '';
if ( $hero_mode === '' ) {
	$legacy_hero = isset( $meta['single_hero_type'] ) ? sanitize_key( $meta['single_hero_type'] ) : 'single_image';
	$legacy_gallery = isset( $meta['gallery_display_mode'] ) ? sanitize_key( $meta['gallery_display_mode'] ) : '';
	if ( $legacy_hero === 'slider_carousel' && $legacy_gallery === 'carousel' ) {
		$hero_mode = 'carousel';
	} elseif ( $legacy_hero === 'slider_carousel' ) {
		$hero_mode = 'slider';
	} else {
		$hero_mode = 'single_image';
	}
}
$hero_images = $gallery_ids;
if ( empty( $hero_images ) && has_post_thumbnail( $tour_id ) ) {
	$hero_images = [ get_post_thumbnail_id( $tour_id ) ];
}
$hero_count = count( $hero_images );
// When 2+ images and no explicit single_image, use slider/carousel (per tour or global setting)
if ( $hero_count > 1 && $hero_mode === 'single_image' ) {
	$hero_mode = isset( $settings['single_hero_gallery_mode'] ) ? sanitize_key( $settings['single_hero_gallery_mode'] ) : 'slider';
}
$hero_is_slider = ( $hero_mode === 'slider' || $hero_mode === 'carousel' ) && $hero_count > 1;
if ( $hero_count === 1 ) {
	$hero_is_slider = false;
}
$hero_gallery_mode = $hero_is_slider ? $hero_mode : ( isset( $settings['single_hero_gallery_mode'] ) ? sanitize_key( $settings['single_hero_gallery_mode'] ) : 'slider' );

// Duration (support both duration and tour_duration)
$duration_days = (int) ($meta['duration']['days'] ?? 0);
$duration_nights = (int) ($meta['duration']['nights'] ?? 0);
$duration_hours = (int) ($meta['duration']['hours'] ?? 0);

// Group size
$min_pax = (int) ($meta['group_size']['min'] ?? 1);
$max_pax = (int) ($meta['group_size']['max'] ?? 20);

// Homepage hero overlay (reuse for single tour hero)
$homepage_opts = get_option('ytrip_homepage', []);
$overlay_hex = isset($homepage_opts['hero_overlay_color']) ? sanitize_hex_color($homepage_opts['hero_overlay_color']) : '#000000';
$overlay_opacity = isset($homepage_opts['hero_overlay_opacity']) ? min(100, max(0, (float) $homepage_opts['hero_overlay_opacity'])) / 100 : 0.5;
$overlay_rgba = 'rgba(0,0,0,0.5)';
if ($overlay_hex) {
    $hex = ltrim($overlay_hex, '#');
    if (strlen($hex) === 3) {
        $hex = $hex[0] . $hex[0] . $hex[1] . $hex[1] . $hex[2] . $hex[2];
    }
    if (strlen($hex) === 6) {
        $rgb = array_map('hexdec', str_split($hex, 2));
        $overlay_rgba = 'rgba(' . implode(',', $rgb) . ',' . $overlay_opacity . ')';
    }
}

// Theme colors: use Brand System so Color Preset and Quick Color Palette are reflected
$primary_color = '#2563eb';
$secondary_color = '';
$accent_color = '';
if ( function_exists( 'ytrip_get_color' ) ) {
	$primary_color = ytrip_get_color( 'primary' );
	$secondary_color = ytrip_get_color( 'secondary' );
	$accent_color = ytrip_get_color( 'accent' );
} else {
	$theme_settings = get_option( 'ytrip_settings', [] );
	$custom_colors = $theme_settings['custom_colors'] ?? [];
	$primary_color = $custom_colors['primary'] ?? $theme_settings['opt_color_primary'] ?? $primary_color;
	$secondary_color = $custom_colors['secondary'] ?? $theme_settings['opt_color_secondary'] ?? '';
	$accent_color = $custom_colors['accent'] ?? $theme_settings['opt_color_accent'] ?? '';
}
// Derive primary-hover (darker) and primary-light (tint) for brand consistency
$hex = ltrim( $primary_color, '#' );
if ( strlen( $hex ) === 3 ) {
	$hex = $hex[0] . $hex[0] . $hex[1] . $hex[1] . $hex[2] . $hex[2];
}
$primary_rgb = array( 37, 99, 235 );
if ( strlen( $hex ) === 6 && preg_match( '/^[a-fA-F0-9]{6}$/', $hex ) ) {
	$primary_rgb = array( hexdec( substr( $hex, 0, 2 ) ), hexdec( substr( $hex, 2, 2 ) ), hexdec( substr( $hex, 4, 2 ) ) );
}
$primary_rgb_str = implode( ',', $primary_rgb );
$primary_hover = ! empty( $secondary_color ) ? $secondary_color : '#' . sprintf( '%02x%02x%02x', max( 0, $primary_rgb[0] - 28 ), max( 0, $primary_rgb[1] - 28 ), max( 0, $primary_rgb[2] - 28 ) );
$primary_light = 'rgba(' . $primary_rgb_str . ',0.12)';

// Dark mode check
$is_dark_mode = isset($_COOKIE['ytrip_theme']) && $_COOKIE['ytrip_theme'] === 'dark';
if (isset($_GET['dark_mode'])) {
    $is_dark_mode = (bool) $_GET['dark_mode'];
}
?>

<?php get_header(); ?>

<div class="ytrip-single-tour-page">
<style>
    /* Brand colors – applied to whole single tour (hero, booking, FAB, main) */
    .ytrip-single-tour-page {
        --ytrip-primary: <?php echo esc_attr( $primary_color ); ?>;
        --ytrip-primary-rgb: <?php echo esc_attr( $primary_rgb_str ); ?>;
        --ytrip-primary-hover: <?php echo esc_attr( $primary_hover ); ?>;
        --ytrip-primary-light: <?php echo esc_attr( $primary_light ); ?>;
        <?php if ( $secondary_color ) : ?>
        --ytrip-secondary: <?php echo esc_attr( $secondary_color ); ?>;
        <?php endif; ?>
        <?php if ( $accent_color ) : ?>
        --ytrip-accent: <?php echo esc_attr( $accent_color ); ?>;
        <?php endif; ?>
        --ytrip-surface: #ffffff;
        --ytrip-surface-alt: #f8fafc;
        --ytrip-text: #1e293b;
        --ytrip-text-muted: #64748b;
        --ytrip-border: #e5e7eb;
    }
    .ytrip-single-tour-page .ytrip-booking-fab__btn {
        background: var(--ytrip-primary) !important;
        color: #fff !important;
        box-shadow: 0 8px 24px rgba(var(--ytrip-primary-rgb), 0.35);
    }
    .ytrip-single-tour-page .ytrip-booking-fab__btn:hover {
        background: var(--ytrip-primary-hover) !important;
        box-shadow: 0 12px 32px rgba(var(--ytrip-primary-rgb), 0.4);
    }
    .ytrip-single-tour-page .ytrip-btn-book {
        background: var(--ytrip-primary) !important;
        box-shadow: 0 4px 14px rgba(var(--ytrip-primary-rgb), 0.25);
    }
    .ytrip-single-tour-page .ytrip-btn-book:hover {
        background: var(--ytrip-primary-hover) !important;
        box-shadow: 0 8px 20px rgba(var(--ytrip-primary-rgb), 0.35);
    }
    .ytrip-single-tour-page .ytrip-booking-card {
        border-top: 3px solid var(--ytrip-primary);
        box-shadow: 0 20px 40px -12px rgba(0,0,0,0.12), 0 0 0 1px rgba(var(--ytrip-primary-rgb),0.08);
    }
    .ytrip-single-tour-page .ytrip-section-title {
        border-inline-start: 4px solid var(--ytrip-primary);
        padding-inline-start: 16px;
    }
    .ytrip-single-tour-page .ytrip-hero-title {
        letter-spacing: -0.02em;
        font-weight: 800;
    }
    .ytrip-single-tour-page .ytrip-form-group input:focus,
    .ytrip-single-tour-page .ytrip-form-group select:focus {
        border-color: var(--ytrip-primary);
        box-shadow: 0 0 0 4px rgba(var(--ytrip-primary-rgb), 0.15);
    }
    .ytrip-single-tour-page .ytrip-number-btn:hover {
        background: var(--ytrip-primary);
        color: #fff;
    }
    .ytrip-single-tour-page .ytrip-btn-outline:hover {
        border-color: var(--ytrip-primary);
        color: var(--ytrip-primary);
    }
    .ytrip-single-tour-page .ytrip-single-main a,
    .ytrip-single-tour-page .ytrip-booking-sheet a {
        color: var(--ytrip-primary);
    }
    .ytrip-single-tour-page .ytrip-single-main a:hover,
    .ytrip-single-tour-page .ytrip-booking-sheet a:hover {
        color: var(--ytrip-primary-hover);
    }
    /* Single hero overlay (same as homepage hero from ytrip_homepage options) */
    .ytrip-single-tour-page .ytrip-hero__overlay,
    .ytrip-single-tour-page .ytrip-hero-overlay {
        background: <?php echo esc_attr( $overlay_rgba ); ?> !important;
    }
</style>
<style>
/* Single tour: prevent horizontal scroll on any screen */
.ytrip-single-tour-page {
    overflow-x: hidden;
}
.ytrip-single-tour-page img,
.ytrip-single-tour-page iframe,
.ytrip-section-content img,
.ytrip-day-description img {
    max-width: 100%;
    height: auto;
}
/* Dark mode: FAB & sheet */
.ytrip-dark-mode .ytrip-booking-fab,
[data-theme="dark"] .ytrip-booking-fab {
    background: linear-gradient(to top, rgba(30,41,59,0.98) 70%, transparent);
}
.ytrip-dark-mode .ytrip-booking-sheet__panel,
[data-theme="dark"] .ytrip-booking-sheet__panel {
    background: var(--ytrip-surface, #1e293b);
}
.ytrip-dark-mode .ytrip-booking-sheet__title,
[data-theme="dark"] .ytrip-booking-sheet__title {
    color: var(--ytrip-text, #f1f5f9);
}
.ytrip-dark-mode .ytrip-booking-sheet__close,
[data-theme="dark"] .ytrip-booking-sheet__close {
    background: var(--ytrip-surface-alt, #334155);
    color: var(--ytrip-text-muted, #94a3b8);
}
</style>

<!-- ==================== HERO SECTION (full width, capped height, same overlay as homepage) ==================== -->
<section class="ytrip-hero ytrip-single-hero ytrip-single-hero--fullwidth ytrip-single-hero--width-full ytrip-single-hero--viewport <?php echo $hero_is_slider ? 'ytrip-hero-slider swiper' : ''; ?>" <?php echo $hero_is_slider ? ' data-hero-mode="' . esc_attr( $hero_gallery_mode ) . '"' : ''; ?>>
    <!-- Background: same structure as homepage (.ytrip-hero__bg) -->
    <div class="ytrip-hero__bg ytrip-hero-bg <?php echo $hero_is_slider ? 'swiper-wrapper' : ''; ?>">
        <?php if ( $hero_is_slider ) : ?>
            <?php foreach ( $hero_images as $i => $img_id ) : ?>
                <div class="swiper-slide ytrip-hero-slide-bg">
                    <?php echo ytrip_hero_image_with_skeleton( (int) $img_id, $i === 0 ); ?>
                </div>
            <?php endforeach; ?>
        <?php else : ?>
            <?php
            $hero_img_id = ! empty( $hero_images[0] ) ? $hero_images[0] : get_post_thumbnail_id( $tour_id );
            if ( $hero_img_id ) :
                echo ytrip_hero_image_with_skeleton( (int) $hero_img_id, true );
            else :
                ?>
                <div class="ytrip-hero__placeholder ytrip-hero-placeholder"></div>
            <?php endif; ?>
        <?php endif; ?>
    </div>
    <?php if ( $hero_is_slider ) : ?>
    <div class="swiper-pagination ytrip-single-hero-pagination"></div>
    <div class="swiper-button-next ytrip-single-hero-next"></div>
    <div class="swiper-button-prev ytrip-single-hero-prev"></div>
    <?php endif; ?>
    <div class="ytrip-hero__overlay ytrip-hero-overlay"></div>

    <!-- Hero Content (same class as homepage for consistent styling) -->
    <div class="ytrip-hero__content ytrip-hero-content">
        <div class="ytrip-container">
            <div class="ytrip-hero-grid">
                <!-- Left: Tour Info -->
                <div class="ytrip-hero-info">
                    <!-- Breadcrumb -->
                    <nav class="ytrip-breadcrumb">
                        <a href="<?php echo esc_url(home_url('/')); ?>"><?php esc_html_e('Home', 'ytrip'); ?></a>
                        <span class="separator">/</span>
                        <a href="<?php echo esc_url(get_post_type_archive_link('ytrip_tour')); ?>"><?php esc_html_e('Tours', 'ytrip'); ?></a>
                        <?php if ($destinations && !is_wp_error($destinations)) : ?>
                            <span class="separator">/</span>
                            <a href="<?php echo esc_url(get_term_link($destinations[0])); ?>"><?php echo esc_html($destinations[0]->name); ?></a>
                        <?php endif; ?>
                    </nav>

                    <!-- Categories -->
                    <?php if ($categories && !is_wp_error($categories)) : ?>
                        <div class="ytrip-hero-categories">
                            <?php foreach ($categories as $cat) : ?>
                                <span class="ytrip-category-badge" style="background-color: <?php echo esc_attr(get_term_meta($cat->term_id, 'color', true) ?: $primary_color); ?>20; color: <?php echo esc_attr(get_term_meta($cat->term_id, 'color', true) ?: $primary_color); ?>;">
                                    <?php echo esc_html($cat->name); ?>
                                </span>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>

                    <!-- Title -->
                    <h1 class="ytrip-hero-title"><?php the_title(); ?></h1>

                    <!-- Quick Info -->
                    <div class="ytrip-hero-meta">
                        <?php if ($destinations && !is_wp_error($destinations)) : ?>
                            <div class="ytrip-meta-item">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                    <circle cx="12" cy="10" r="3"></circle>
                                </svg>
                                <span><?php echo esc_html($destinations[0]->name); ?></span>
                            </div>
                        <?php endif; ?>

                        <?php if ($duration_days > 0 || $duration_hours > 0) : ?>
                            <div class="ytrip-meta-item">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <polyline points="12 6 12 12 16 14"></polyline>
                                </svg>
                                <span>
                                    <?php
                                    if ($duration_days > 0) {
                                        printf(
                                            _n('%d Day', '%d Days', $duration_days, 'ytrip'),
                                            $duration_days
                                        );
                                        if ($duration_nights > 0) {
                                            printf(' / %s', _n('%d Night', '%d Nights', $duration_nights, 'ytrip'));
                                        }
                                    } elseif ($duration_hours > 0) {
                                        printf(_n('%d Hour', '%d Hours', $duration_hours, 'ytrip'), $duration_hours);
                                    }
                                    ?>
                                </span>
                            </div>
                        <?php endif; ?>

                        <div class="ytrip-meta-item">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                <circle cx="9" cy="7" r="4"></circle>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                            </svg>
                            <span><?php printf(__('%d-%d People', 'ytrip'), $min_pax, $max_pax); ?></span>
                        </div>

                        <?php if (!empty($meta['difficulty'])) : ?>
                            <div class="ytrip-meta-item">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                                </svg>
                                <span class="ytrip-difficulty ytrip-difficulty--<?php echo esc_attr($meta['difficulty']); ?>">
                                    <?php
                                    $difficulties = [
                                        'easy' => __('Easy', 'ytrip'),
                                        'moderate' => __('Moderate', 'ytrip'),
                                        'challenging' => __('Challenging', 'ytrip'),
                                        'extreme' => __('Extreme', 'ytrip'),
                                    ];
                                    echo esc_html($difficulties[$meta['difficulty']] ?? $meta['difficulty']);
                                    ?>
                                </span>
                            </div>
                        <?php endif; ?>
                    </div>

                    <!-- Rating -->
                    <?php if ($product && $product->get_average_rating() > 0) : ?>
                        <div class="ytrip-hero-rating">
                            <div class="ytrip-stars">
                                <?php for ($i = 1; $i <= 5; $i++) : ?>
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="<?php echo $i <= round($product->get_average_rating()) ? 'var(--ytrip-accent, #f59e0b)' : 'none'; ?>" stroke="var(--ytrip-accent, #f59e0b)" stroke-width="2">
                                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                                    </svg>
                                <?php endfor; ?>
                            </div>
                            <span class="ytrip-rating-value"><?php echo esc_html(number_format($product->get_average_rating(), 1)); ?></span>
                            <span class="ytrip-rating-count">(<?php echo esc_html($product->get_review_count()); ?> <?php esc_html_e('reviews', 'ytrip'); ?>)</span>
                        </div>
                    <?php endif; ?>

                    <!-- Excerpt -->
                    <?php if (has_excerpt()) : ?>
                        <div class="ytrip-hero-excerpt">
                            <?php the_excerpt(); ?>
                        </div>
                    <?php endif; ?>
                </div>

                <!-- Right: Booking Form -->
                <?php do_action( 'ytrip_before_booking_form' ); ?>
                <div class="ytrip-hero-booking">
                    <div class="ytrip-booking-card">
                        <!-- Price (WooCommerce or tour meta) -->
                        <div class="ytrip-booking-price">
                            <?php if ($product) : ?>
                                <?php if ($product->is_on_sale()) : ?>
                                    <span class="ytrip-price-label"><?php esc_html_e('From', 'ytrip'); ?></span>
                                    <span class="ytrip-price-original"><?php echo wc_price($product->get_regular_price()); ?></span>
                                <?php endif; ?>
                                <span class="ytrip-price-current"><?php echo $product->get_price_html(); ?></span>
                                <span class="ytrip-price-per"><?php esc_html_e('per person', 'ytrip'); ?></span>
                            <?php elseif ($tour_price_html !== '') : ?>
                                <span class="ytrip-price-label"><?php esc_html_e('From', 'ytrip'); ?></span>
                                <span class="ytrip-price-current"><?php echo esc_html($tour_price_html); ?></span>
                                <span class="ytrip-price-per"><?php esc_html_e('per person', 'ytrip'); ?></span>
                            <?php else : ?>
                                <span class="ytrip-price-current"><?php esc_html_e('Contact for Price', 'ytrip'); ?></span>
                            <?php endif; ?>
                        </div>

                        <!-- Booking Form -->
                        <?php $ytrip_booking_user = wp_get_current_user(); ?>
                        <form class="ytrip-booking-form" method="post" action="">
                            <?php wp_nonce_field('ytrip_booking', 'ytrip_booking_nonce'); ?>
                            <input type="hidden" name="tour_id" value="<?php echo esc_attr($tour_id); ?>">
                            <?php if ($product) : ?>
                            <input type="hidden" name="add-to-cart" value="<?php echo esc_attr($product_id); ?>">
                            <?php endif; ?>
                            <input type="hidden" name="infants" value="0">
                            <input type="hidden" name="recaptcha_token" value="">

                            <!-- Date -->
                            <div class="ytrip-form-group">
                                <label for="booking_date"><?php esc_html_e('Select Date', 'ytrip'); ?> <span class="required">*</span></label>
                                <input type="date" id="booking_date" name="booking_date" required min="<?php echo esc_attr(date('Y-m-d', strtotime('+1 day'))); ?>">
                            </div>

                            <!-- Adults -->
                            <div class="ytrip-form-group">
                                <label for="adults"><?php esc_html_e('Adults', 'ytrip'); ?> <span class="required">*</span></label>
                                <div class="ytrip-number-input" role="group" aria-label="<?php esc_attr_e('Adults', 'ytrip'); ?>">
                                    <button type="button" class="ytrip-number-btn minus" data-target="adults" data-min="1" aria-label="<?php esc_attr_e('Decrease adults', 'ytrip'); ?>">-</button>
                                    <input type="number" id="adults" name="adults" value="2" min="1" max="<?php echo esc_attr($max_pax); ?>" required aria-valuenow="2" aria-valuemin="1" aria-valuemax="<?php echo esc_attr($max_pax); ?>">
                                    <button type="button" class="ytrip-number-btn plus" data-target="adults" data-max="<?php echo esc_attr($max_pax); ?>" aria-label="<?php esc_attr_e('Increase adults', 'ytrip'); ?>">+</button>
                                </div>
                            </div>

                            <!-- Children -->
