<!-- ==================== MAIN CONTENT ==================== -->
<main class="ytrip-single-main">
    <div class="ytrip-container">
        <div class="ytrip-content-grid">
            
            <!-- Left Column: Content -->
            <div class="ytrip-content-main">
                
                <!-- Section: Tour information – all features and specs -->
                <?php
                $tour_info_items = [];
                if (!empty($meta['tour_code'])) {
                    $tour_info_items[] = ['label' => __('Tour Code', 'ytrip'), 'value' => esc_html($meta['tour_code']), 'icon' => 'tag'];
                }
                if ($duration_days > 0 || $duration_nights > 0 || $duration_hours > 0) {
                    $parts = [];
                    if ($duration_days > 0) $parts[] = sprintf(_n('%d Day', '%d Days', $duration_days, 'ytrip'), $duration_days);
                    if ($duration_nights > 0) $parts[] = sprintf(_n('%d Night', '%d Nights', $duration_nights, 'ytrip'), $duration_nights);
                    if ($duration_hours > 0) $parts[] = sprintf(_n('%d Hour', '%d Hours', $duration_hours, 'ytrip'), $duration_hours);
                    if (!empty($parts)) {
                        $tour_info_items[] = ['label' => __('Duration', 'ytrip'), 'value' => implode(' / ', $parts), 'icon' => 'clock'];
                    }
                }
                $group_size = isset($meta['group_size']) && is_array($meta['group_size']) ? $meta['group_size'] : [];
                if (!empty($group_size['min']) || !empty($group_size['max'])) {
                    $min = (int) ($group_size['min'] ?? 1);
                    $max = (int) ($group_size['max'] ?? 20);
                    $tour_info_items[] = ['label' => __('Group Size', 'ytrip'), 'value' => $min === $max ? (string) $max : $min . ' – ' . $max, 'icon' => 'users'];
                }
                if (!empty($meta['difficulty'])) {
                    $diffs = ['easy' => __('Easy', 'ytrip'), 'moderate' => __('Moderate', 'ytrip'), 'challenging' => __('Challenging', 'ytrip'), 'extreme' => __('Extreme', 'ytrip'), 'difficult' => __('Difficult', 'ytrip'), 'expert' => __('Expert', 'ytrip')];
                    $tour_info_items[] = ['label' => __('Difficulty', 'ytrip'), 'value' => esc_html($diffs[$meta['difficulty']] ?? $meta['difficulty']), 'icon' => 'activity'];
                }
                if (!empty($meta['tour_type'])) {
                    $types = ['group' => __('Group Tour', 'ytrip'), 'private' => __('Private Tour', 'ytrip'), 'self' => __('Self-Guided', 'ytrip')];
                    $tour_info_items[] = ['label' => __('Tour Type', 'ytrip'), 'value' => esc_html($types[$meta['tour_type']] ?? $meta['tour_type']), 'icon' => 'users'];
                }
                $age_restriction = isset($meta['age_restriction']) && is_array($meta['age_restriction']) ? $meta['age_restriction'] : [];
                $min_age = (int) ($age_restriction['min_age'] ?? 0);
                $max_age = (int) ($age_restriction['max_age'] ?? 99);
                if ($min_age > 0 || $max_age < 99) {
                    if ($min_age > 0 && $max_age < 99) {
                        $age_str = sprintf(__('%1$d – %2$d years', 'ytrip'), $min_age, $max_age);
                    } elseif ($min_age > 0) {
                        $age_str = sprintf(__('Minimum %d years', 'ytrip'), $min_age);
                    } else {
                        $age_str = sprintf(__('Maximum %d years', 'ytrip'), $max_age);
                    }
                    $tour_info_items[] = ['label' => __('Age Range', 'ytrip'), 'value' => $age_str, 'icon' => 'user'];
                }
                if (!empty($meta['languages']) && is_array($meta['languages'])) {
                    $tour_info_items[] = ['label' => __('Languages', 'ytrip'), 'value' => implode(', ', array_map('esc_html', $meta['languages'])), 'icon' => 'globe'];
                } elseif (!empty($meta['languages'])) {
                    $tour_info_items[] = ['label' => __('Languages', 'ytrip'), 'value' => esc_html($meta['languages']), 'icon' => 'globe'];
                }
                if (!empty($meta['meeting_point'])) {
                    $tour_info_items[] = ['label' => __('Meeting Point', 'ytrip'), 'value' => esc_html($meta['meeting_point']), 'icon' => 'map-pin'];
                }
                if (!empty($meta['meeting_time'])) {
                    $tour_info_items[] = ['label' => __('Meeting Time', 'ytrip'), 'value' => esc_html($meta['meeting_time']), 'icon' => 'clock'];
                }
                if (!empty($meta['end_point']) && $meta['end_point'] !== ($meta['meeting_point'] ?? '')) {
                    $tour_info_items[] = ['label' => __('End Point', 'ytrip'), 'value' => esc_html($meta['end_point']), 'icon' => 'flag'];
                }
                if (!empty($meta['what_to_bring'])) {
                    $tour_info_items[] = ['label' => __('What to Bring', 'ytrip'), 'value' => wp_kses_post($meta['what_to_bring']), 'icon' => 'package', 'allow_html' => true];
                }
                if (!empty($meta['know_before'])) {
                    $tour_info_items[] = ['label' => __('Know Before You Go', 'ytrip'), 'value' => wp_kses_post($meta['know_before']), 'icon' => 'info', 'allow_html' => true];
                }
                if (!empty($meta['cancellation_policy'])) {
                    $tour_info_items[] = ['label' => __('Cancellation Policy', 'ytrip'), 'value' => wp_kses_post($meta['cancellation_policy']), 'icon' => 'file-text', 'allow_html' => true];
                }
                if (!empty($meta['custom_fields']) && is_array($meta['custom_fields'])) {
                    foreach ($meta['custom_fields'] as $cf) {
                        $label = isset($cf['label']) ? trim($cf['label']) : '';
                        $value = isset($cf['value']) ? trim($cf['value']) : '';
                        if ($label !== '' && $value !== '') {
                            $tour_info_items[] = ['label' => esc_html($label), 'value' => esc_html($value), 'icon' => 'tag'];
                        }
                    }
                }
                ?>
                <?php if (!empty($tour_info_items)) : ?>
                    <section class="ytrip-section ytrip-section-tour-info">
                        <h2 class="ytrip-section-title">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"></circle>
                                <line x1="12" y1="16" x2="12" y2="12"></line>
